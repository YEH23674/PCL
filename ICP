void print_Transformation_Matrix4f(const Eigen::Matrix4f& transform)
{
    cout << "The Estimated Rotation and translation matrices (using getTransformation function) are : \n" << endl;
    printf("\n");
    printf("    | %12.6f %12.6f %12.6f | \n", transform(0, 0), transform(0, 1), transform(0, 2));
    printf("R = | %12.6f %12.6f %12.6f | \n", transform(1, 0), transform(1, 1), transform(1, 2));
    printf("    | %12.6f %12.6f %12.6f | \n", transform(2, 0), transform(2, 1), transform(2, 2));
    printf("\n");
    printf("t = < %0.6f, %0.6f, %0.6f >\n", transform(0, 3), transform(1, 3), transform(2, 3));
}

void svd_registration(pcl::PointCloud<pcl::PointXYZ>::Ptr &Source_, 
    pcl::PointCloud<pcl::PointXYZ>::Ptr &Target_, pcl::PointCloud<pcl::PointXYZ>::Ptr &out_,
    Eigen::Matrix4f &T_)
{
    //SVD配准，求解变换矩阵
    pcl::registration::TransformationEstimationSVD<pcl::PointXYZ, pcl::PointXYZ> svd;
    //pcl::registration::TransformationEstimationSVD<pcl::PointXYZ, pcl::PointXYZ>::Matrix4 trans_svd;
    svd.estimateRigidTransformation(*Source_, *Target_, T_);
    //点云变换
    pcl::transformPointCloud(*Source_, *out_, T_);
}

void icp_registration(pcl::PointCloud<pcl::PointXYZ>::Ptr& Source_,
	pcl::PointCloud<pcl::PointXYZ>::Ptr& Target_, pcl::PointCloud<pcl::PointXYZ>::Ptr& out_,
    Eigen::Matrix4f &T_)
{
    pcl::IterativeClosestPoint<pcl::PointXYZ, pcl::PointXYZ> icp;
    icp.setInputSource(Source_);             // 源点云
    icp.setInputTarget(Target_);             // 目标点云
    //icp.setTransformationEpsilon(1e-10);    // 为终止条件设置最小转换差异
    //icp.setMaxCorrespondenceDistance(5);    // 设置对应点对之间的最大距离（此值对配准结果影响较大）。
    //icp.setEuclideanFitnessEpsilon(0.001);  // 设置收敛条件是均方误差和小于阈值， 停止迭代；
    //icp.setMaximumIterations(35);           // 最大迭代次数
    //icp.setUseReciprocalCorrespondences(true);//设置为true,则使用相互对应关系
    // 计算需要的刚体变换以便将输入的源点云匹配到目标点云
    //pcl::PointCloud<pcl::PointXYZ>::Ptr icp_cloud(new pcl::PointCloud<pcl::PointXYZ>);
    icp.align(*out_, Eigen::Matrix4f::Identity());
    //cout << "Applied " << 35 << " ICP iterations in " << time.toc() << " ms" << endl;
    cout << "\nICP has converged, score is " << icp.getFitnessScore() << endl;
    T_ = icp.getFinalTransformation();
    //cout << "变换矩阵：\n" << icp.getFinalTransformation() << endl;
    // 使用创建的变换对为输入源点云进行变换
    pcl::transformPointCloud(*Source_, *out_, T_);
}

void PCL_visualization(pcl::PointCloud<pcl::PointXYZ>::Ptr &Source_,
    pcl::PointCloud<pcl::PointXYZ>::Ptr &Target_, pcl::PointCloud<pcl::PointXYZ>::Ptr &out_)
{
    boost::shared_ptr<pcl::visualization::PCLVisualizer> view(new pcl::visualization::PCLVisualizer("3D Viewer"));
    view->setBackgroundColor(49.0 / 255.0, 92.0 / 255.0, 143.0 / 255.0);
    view->addCoordinateSystem();

    //手动设置颜色
    pcl::visualization::PointCloudColorHandlerCustom<pcl::PointXYZ> Source_Color(Source_, 255, 0, 0);
    pcl::visualization::PointCloudColorHandlerCustom<pcl::PointXYZ> Target_Color(Target_, 0, 255, 0);
    pcl::visualization::PointCloudColorHandlerCustom<pcl::PointXYZ> Out_Color(out_, 255, 0, 0);

    view->addPointCloud<pcl::PointXYZ>(Source_, Source_Color, "Source");
    view->addPointCloud<pcl::PointXYZ>(Target_, Target_Color, "Target");
    view->addPointCloud<pcl::PointXYZ>(out_, Out_Color, "out");

    // 设置点云的点大小
    double Source_size = 5.5, Target_size = 7.5, Out_size = 3.5;
    view->setPointCloudRenderingProperties(pcl::visualization::PCL_VISUALIZER_POINT_SIZE, Source_size, "Source");
    view->setPointCloudRenderingProperties(pcl::visualization::PCL_VISUALIZER_POINT_SIZE, Target_size, "Target");
    view->setPointCloudRenderingProperties(pcl::visualization::PCL_VISUALIZER_POINT_SIZE, Out_size, "out");

    while (!view->wasStopped())
    {
        view->spinOnce(100);
        boost::this_thread::sleep(boost::posix_time::microseconds(100000));
    }
}

// ***************** 求旋转矩阵的函数 ********************** 
Eigen::Matrix3f calc_rotation_matrix(double alpha, double beta, double gamma)
{
    Eigen::Matrix3f R;
    R(0, 0) = cos(gamma) * cos(beta); R(0, 1) = -sin(gamma) * cos(alpha) + cos(gamma) * sin(beta) * sin(alpha);
    R(0, 2) = sin(gamma) * sin(alpha) + cos(gamma) * sin(beta) * cos(alpha);
    R(1, 0) = sin(gamma) * cos(beta); R(1, 1) = cos(gamma) * cos(alpha) + sin(gamma) * sin(beta) * sin(alpha);
    R(1, 2) = -cos(gamma) * sin(alpha) + sin(gamma) * sin(beta) * cos(alpha);
    R(2, 0) = -sin(beta); R(2, 1) = cos(beta) * sin(alpha); R(2, 2) = cos(beta) * cos(alpha);

    return R;
}

// ******** 重心化函数 **************
void calc_centroid(pcl::PointCloud<pcl::PointXYZ>::Ptr& in_cloud, pcl::PointCloud<pcl::PointXYZ>::Ptr& out_cloud)
{
    // 深拷贝；浅拷贝
    //重心化
    // 复制点云(深拷贝)
    //pcl::copyPointCloud(*in_cloud, *out_cloud);
    
    *out_cloud = *in_cloud;
    for (int i = 0; i < in_cloud->points.size(); i++)
    {
        out_cloud->points[i].x = in_cloud->points[i].x;
        out_cloud->points[i].y = in_cloud->points[i].y;
        out_cloud->points[i].z = in_cloud->points[i].z;
    }
    
    Eigen::Vector3f centroid(0, 0, 0);   //定义重心
    // 计算Source的质心（所有点的均值）
    for (const auto& p : out_cloud->points)
        centroid += Eigen::Vector3f(p.x, p.y, p.z);
    centroid /= out_cloud->size();

    // Source每个点减去质心
    for (auto& p : out_cloud->points)
    {
        p.x -= centroid.x();
        p.y -= centroid.y();
        p.z -= centroid.z();
    }
}

